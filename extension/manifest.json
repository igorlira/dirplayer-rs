{
  "manifest_version": 3,
  "name": "DirPlayer - Shockwave Emulator",
  "short_name": "DirPlayer",
  "version": "0.5.0",
  "action": {
    "default_title": "DirPlayer",
    "default_popup": "extension/index.html",
    "default_icon": "logo192.png"
  },
  "description": "Play Shockwave content directly from your browser.",
  "homepage_url": "https://github.com/igorlira/dirplayer-rs",
  "icons": {
    "128": "logo128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["extension/src/content-script.tsx"],
      "all_frames": true,
      "media": [],
      "run_at": "document_start"
    }
  ],
  "host_permissions": ["<all_urls>"],
  "permissions": ["scripting"],
  "background": {
    "service_worker": "extension/src/background.ts",
    "type": "module"
  },
  "web_accessible_resources": [{
    "resources": [
      "vm-rust/pkg/*",
      "charmap-system.png",
      "dirplayer-shockwave-polyfill.js",
      "dirplayer-ruffle-bridge-host.js",
      "dirplayer-pre-init.js",
      "ruffle/*"
    ],
    "matches": ["<all_urls>"]
  }]
}
